{
  "name": "doc2alpaca",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/postbuild.js",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test tests/*.test.ts",
    "electron:setup": "node scripts/install-electron.js",
    "electron:dev": "concurrently -k -n next,electron \"next dev -p 3457\" \"wait-on -t 120000 -i 3000 http://localhost:3457 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build:win": "next build && node scripts/postbuild.js && electron-builder --win --x64",
    "electron:build:mac": "next build && node scripts/postbuild.js && electron-builder --mac",
    "electron:build:linux": "next build && node scripts/postbuild.js && electron-builder --linux",
    "prebuild": "node scripts/purge-sensitive-temp.js",
    "prestart": "node scripts/purge-sensitive-temp.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "mammoth": "^1.6.0",
    "marked": "^12.0.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^4.52.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.doc2alpaca.app",
    "productName": "Doc2Alpaca",
    "copyright": "Copyright © 2026",
    "directories": {
      "buildResources": "build",
      "output": "release_build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      },
      {
        "from": ".next/static",
        "to": "app/.next/static"
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Doc2Alpaca"
    },
    "portable": {
      "artifactName": "Doc2Alpaca-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
