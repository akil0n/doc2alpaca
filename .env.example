# PostgreSQL connection (TLS parameters are recommended in production)
DATABASE_URL="postgresql://user:password@localhost:5432/doc2alpaca"

# Generate each value independently with: openssl rand -base64 32
# Keep both values stable across deployments and store them in a server-side secret store.
AUTH_SECRET=""
DATA_ENCRYPTION_KEY=""

# Canonical public origin, for example https://example.com
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth providers. A provider is hidden when either value is missing.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_WECHAT_ID=""
AUTH_WECHAT_SECRET=""
AUTH_QQ_ID=""
AUTH_QQ_SECRET=""

# Tencent Cloud SMS (mainland China phone login)
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
TENCENT_SMS_REGION="ap-guangzhou"
TENCENT_SMS_SDK_APP_ID=""
TENCENT_SMS_SIGN_NAME=""
TENCENT_SMS_TEMPLATE_ID=""

# Optional server-owned LLM fallback
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o"

# Comma-separated, pre-audited extra HTTPS hostnames allowed for user LLM configs.
# Do not add private, loopback, link-local, wildcard, or user-controlled domains.
LLM_ALLOWED_HOSTS=""
